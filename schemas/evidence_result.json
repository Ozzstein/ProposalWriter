{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidenceResult",
  "description": "Output from retriever agents (literature_searcher, patent_scanner, etc.)",
  "type": "object",
  "properties": {
    "task_id": { "type": "string" },
    "topic": { "type": "string" },
    "summary": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_id": { "type": "string", "pattern": "^SRC-\\d+$" },
          "title": { "type": "string" },
          "authors": { "type": "string" },
          "year": { "type": "integer" },
          "type": { "type": "string", "enum": ["paper", "patent", "standard", "internal", "report", "review"] },
          "quality": { "type": "string", "enum": ["low", "medium", "high"] },
          "extract": { "type": "string", "description": "Key findings or relevant excerpt" },
          "limitations": { "type": "array", "items": { "type": "string" } },
          "relevance_tags": { "type": "array", "items": { "type": "string" } },
          "url": { "type": "string" },
          "doi": { "type": "string" },
          "full_text_available": { "type": "boolean", "description": "False if only abstract/metadata retrieved (paywall)" },
          "oa_url": { "type": "string", "description": "Open-access PDF URL resolved via Unpaywall or ResearchGate" }
        },
        "required": ["source_id", "title", "year", "type", "quality", "extract"]
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim_text": { "type": "string" },
          "source_ids": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["claim_text", "source_ids", "confidence"]
      }
    },
    "gaps": { "type": "array", "items": { "type": "string" } },
    "next_steps": { "type": "array", "items": { "type": "string" } },
    "paywalled_dois": {
      "type": "array",
      "items": { "type": "string" },
      "description": "DOIs of relevant papers where only abstract was available; passed to web_scraper for Unpaywall resolution"
    }
  },
  "required": ["task_id", "topic", "summary", "sources"]
}

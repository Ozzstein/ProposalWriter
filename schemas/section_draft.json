{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SectionDraft",
  "description": "Output from writer agents",
  "type": "object",
  "properties": {
    "section_name": { "type": "string" },
    "target_audience": { "type": "string" },
    "draft_text": { "type": "string" },
    "claim_ids": { "type": "array", "items": { "type": "string" }, "description": "Claims referenced in this section" },
    "source_ids": { "type": "array", "items": { "type": "string" }, "description": "Sources cited in this section" },
    "assumptions_used": { "type": "array", "items": { "type": "string" } },
    "open_issues": { "type": "array", "items": { "type": "string" } },
    "word_count": { "type": "integer" }
  },
  "required": ["section_name", "draft_text", "claim_ids"]
}
